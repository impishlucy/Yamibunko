```gitignore
# ---------------------------------------------------------
# OS / misc
# ---------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini
*.pem


# ---------------------------------------------------------
# JetBrains IDEs: WebStorm / Rider / IntelliJ / Android Studio
# ---------------------------------------------------------
.idea/
/.idea/caches
/.idea/libraries
/.idea/modules.xml
/.idea/workspace.xml
/.idea/navEditor.xml
/.idea/assetWizardSettings.xml
.idea_modules/
*.iml
*.iws
*.ipr

# JetBrains user/workspace files
*.sln.iml
*.sln.DotSettings.user


# ---------------------------------------------------------
# Environment / local config
# ---------------------------------------------------------
.env
.env.*
!.env.example
!.env.sample


# ---------------------------------------------------------
# Logs / debug
# ---------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
bun-debug.log*


# ---------------------------------------------------------
# JavaScript / TypeScript / Bun / Next.js
# Applies to webapp/ and any other nested JS workspace.
# ---------------------------------------------------------

# dependencies
node_modules/
.pnp/
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# package-manager stores / caches
.npm/
.pnpm-store/
.bun/

# testing
coverage/

# Next.js
.next/
out/

# caches
.cache/
.turbo/
.vercel/
.yamibunko/

# TypeScript / Next generated files
*.tsbuildinfo
next-env.d.ts


# ---------------------------------------------------------
# C# / .NET / Rider launcher project
# Applies to launcher/ and any nested .NET project.
# ---------------------------------------------------------

# Visual Studio / Rider local state
.vs/

# build output
bin/
obj/
artifacts/

# test output
TestResults/
coverage/
coverage.cobertura.xml

# NuGet
packages/
*.nupkg
*.snupkg
project.assets.json
project.nuget.cache
.nuget/
.dotnet/

# user-specific project files
*.user
*.rsuser
*.suo
*.userosscache
*.sln.docstates

# local app settings / secrets
appsettings.Local.json
appsettings.*.local.json


# ---------------------------------------------------------
# Android / Android Studio / Gradle
# Applies to android/ and any nested Android project.
# ---------------------------------------------------------

# Gradle / Build caches
.gradle/
gradle-app.setting
!gradle-wrapper.jar

# Android Studio local configuration (SDK/NDK paths)
local.properties
/local.properties

# Android build generated files
captures/
/captures
.externalNativeBuild/
.cxx/
*.apk
*.ap_
*.aab
*.dex
*.class

# Keystores / signing (crucial to keep local)
*.keystore
*.jks

# NDK
obj/local/


# ---------------------------------------------------------
# Release / packaged output
# ---------------------------------------------------------
release/
releases/
publish/
build/
dist/
Builds/
*.zip
*.7z
*.tar
*.tar.gz
*.apk
```
