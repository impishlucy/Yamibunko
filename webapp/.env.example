INPUT_FOLDER_PATH=/path/to/input
OUTPUT_FOLDER_PATH=/path/to/output

FFMPEG_DIR=/path/to/ffmpeg_ffprobe

TRANSCODE_ACCEL=nvenc
# nvenc, intel_gpu, intel_cpu, amd_gpu, amd_cpu, or cpu
# Yamibunko probes the selected encoder on .env startup if IMPORT_ENABLED=true and hard fails if AV1 hardware encoding is unavailable for the selected accelerator.
# If you do not have a AV1 encoding HW, fall back to software (cpu).

BASE_URL=http://localhost:3000

ANILIST_CLIENT_ID=your_anilist_client_id
ANILIST_CLIENT_SECRET=your_anilist_client_secret

IMPORT_ENABLED=true
# App behavior // Recommended: true
# Behavior on true:
# Default workflow. Picks up new video files in the input folder,
# converts unsupported or oversized files to AV1 WebM using hardware encoding,
# puts the result in the output folder, then deletes the input file.
# Behavior on false:
# Catalog mode for existing high-quality libraries or if AV1 HW encoding is unsupported. Serves input files in place; no converting, compressing, moving or deleting.


# For Developers only.
ENABLBE_DEBUG_LOG=false
# Set to true to print verbose [Debug] diagnostic logs.
