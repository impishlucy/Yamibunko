<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Launcher.App"
             RequestedThemeVariant="Dark">
    <Application.Styles>
        <FluentTheme />
        <Style Selector="Window">
            <Setter Property="Background" Value="#1a1a1a"/>
        </Style>
        <Style Selector="Button">
            <Setter Property="Background" Value="#6B21A8"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <Style Selector="Button:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#8B5CF6"/>
        </Style>
    </Application.Styles>

    <TrayIcon.Icons>
        <TrayIcons>
            <TrayIcon Icon="avares://Launcher/Assets/icon.ico" ToolTipText="Yamibunko">
                <TrayIcon.Menu>
                    <NativeMenu>
                        <NativeMenuItem Header="Show Logs" Click="OnShowLogsClicked"/>
                        <NativeMenuItemSeparator/>
                        <NativeMenuItem Header="Stop Server &amp; Exit" Click="OnExitClicked"/>
                    </NativeMenu>
                </TrayIcon.Menu>
            </TrayIcon>
        </TrayIcons>
    </TrayIcon.Icons>
</Application>
